PROJECT_NAME=Validation Engine - Solar One HUB
VERSION=0.1.0
SERVICE_LAYER=api
RUN_DB_MIGRATIONS_ON_BOOT=false
WORKER_POLL_SECONDS=20
WORKER_BATCH_SIZE=50
DS_LOOKBACK_HOURS=24
DS_ENABLE_EXTERNAL_FETCH=true
DEFAULT_GRID_ZONE=BR-CS

# Legacy PostgreSQL used by existing validation-engine modules
POSTGRES_USER=solarone
POSTGRES_PASSWORD=solarone_secret
POSTGRES_DB=validation_engine
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DSN=

# Enable dual-DB ingest API for inverter telemetry
SOA_ENABLE_INGEST=true

# MariaDB transactional DB (sql_hec_soa/mysql_schema.sql)
SOA_MYSQL_USER=solarone
SOA_MYSQL_PASSWORD=solarone_secret
SOA_MYSQL_DB=soa_sos
SOA_MYSQL_HOST=mariadb
SOA_MYSQL_PORT=3306

# PostgreSQL Timeseries DB (sql_hec_soa/postgres_timeseries.sql)
SOA_TIMESERIES_USER=solarone
SOA_TIMESERIES_PASSWORD=solarone_secret
SOA_TIMESERIES_DB=validation_engine
SOA_TIMESERIES_HOST=db
SOA_TIMESERIES_PORT=5432

# External integrations (SOA gateway parity)
SOLCAST_API_KEY=
SOLCAST_BASE_URL=https://api.solcast.com.au
COPERNICUS_CLIENT_ID=
COPERNICUS_CLIENT_SECRET=
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api
INMET_BASE_URL=https://apitempo.inmet.gov.br
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/3.0
ELECTRICITY_MAPS_KEY=
ELECTRICITY_MAPS_URL=https://api.electricitymap.org/v3
